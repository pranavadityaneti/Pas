generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["auth", "public"]
}

model Profile {
  id                      String    @id @db.Uuid
  updatedAt               DateTime? @map("updated_at") @db.Timestamptz(6)
  fullName                String?   @map("full_name")
  avatarUrl               String?   @map("avatar_url")
  tier                    String?   @default("Member")
  credits                 Decimal?  @default(0.00) @db.Decimal(10, 2)
  couponsCount            Int?      @default(0) @map("coupons_count")
  dateOfBirth             DateTime? @map("date_of_birth") @db.Date
  notificationPreferences Json?     @default("{\"sms\": false, \"push\": true, \"email\": true, \"orders\": true, \"security\": true, \"marketing\": false}") @map("notification_preferences")
  securityPreferences     Json?     @default("{\"biometric\": false, \"two_factor\": false}") @map("security_preferences")
  profileCompleted        Boolean?  @default(false) @map("profile_completed")
  email                   String?
  razorpayCustomerId      String?   @unique @map("razorpay_customer_id")
  user                    users     @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([profileCompleted], map: "idx_profiles_profile_completed")
  @@map("profiles")
  @@schema("public")
}

model City {
  id           String        @id @default(uuid())
  name         String        @unique
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  serviceAreas ServiceArea[]
  stores       Store[]

  @@schema("public")
}

model ServiceArea {
  id        String   @id @default(uuid())
  cityId    String
  pincode   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  city      City     @relation(fields: [cityId], references: [id])

  @@schema("public")
}

model Vertical {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String          @unique
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now())
  color           String?
  icon            String?
  Product         Product[]
  stores          Store[]
  tier2Categories Tier2Category[]
  merchants       Merchant[]
  sync_queue      SyncQueue[]

  @@map("Vertical")
  @@schema("public")
}

model Tier2Category {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now())
  verticalId  String      @map("vertical_id") @db.Uuid
  image       String?
  Product     Product[]
  vertical    Vertical    @relation(fields: [verticalId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sync_queue  SyncQueue[]

  @@unique([verticalId, name])
  @@index([verticalId])
  @@map("Tier2Category")
  @@schema("public")
}

model User {
  id                      String         @id @default(uuid()) @db.Uuid
  email                   String         @unique
  passwordHash            String?
  role                    Role           @default(CONSUMER)
  name                    String?
  phone                   String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  notificationPreferences Json?          @map("notification_preferences")
  managedStore            Store?         @relation("StoreManager")
  notifications           Notification[]
  orders                  Order[]        @relation("CustomerOrders")

  @@schema("public")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id") @db.Uuid
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  link      String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@map("notifications")
  @@schema("public")
}

model Store {
  id             String         @id @default(uuid()) @db.Uuid
  name           String
  cityId         String
  address        String?
  image          String?
  latitude       Float?
  longitude      Float?
  managerId      String?        @unique @db.Uuid
  active         Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  merchantId     String?        @map("merchant_id")
  operatingDays  String[]       @map("operating_days")
  operatingHours Json?          @map("operating_hours")
  verticalId     String?        @map("vertical_id") @db.Uuid
  city           City           @relation(fields: [cityId], references: [id])
  manager        User?          @relation("StoreManager", fields: [managerId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  vertical       Vertical?      @relation(fields: [verticalId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products       StoreProduct[]
  orders         Order[]
  staff          StoreStaff[]

  @@index([merchantId])
  @@index([verticalId])
  @@schema("public")
}

model StoreStaff {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId    String   @map("store_id") @db.Uuid
  authUserId String?  @unique @map("auth_user_id") @db.Uuid
  name       String
  role       String
  phone      String   @unique
  activities Json     @default("[]")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("store_staff")
  @@schema("public")
}

model Coupon {
  id             String         @id @default(dbgenerated("gen_random_uuid()"))
  code           String         @unique(map: "Coupon_code_key")
  discountType   DiscountType   @map("discount_type")
  discountValue  Float          @map("discount_value")
  maxDiscountCap Float?         @map("max_discount_cap")
  fundingSource  FundingSource  @map("funding_source")
  targetAudience TargetAudience @map("target_audience")
  storeId        String?        @map("store_id") @db.Uuid
  isActive       Boolean        @default(true) @map("is_active")
  usageLimit     Int?           @map("usage_limit")
  usedCount      Int            @default(0) @map("used_count")
  startDate      DateTime       @default(now()) @map("start_date")
  endDate        DateTime?      @map("end_date")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([code], map: "Coupon_code_idx")
  @@index([storeId], map: "Coupon_store_id_idx")
  @@map("coupons")
  @@schema("public")
}

model Product {
  id               String            @id @default(uuid())
  name             String
  description      String?
  image            String?
  mrp              Float
  brand            String?
  ean              String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  unitType         String?
  unitValue        Float?
  hsnCode          String?
  gstRate          Float?
  createdByStoreId String?
  sourceProductId  String?           @unique @map("source_product_id")
  source           String?
  subcategory      String?
  unitPrice        Float?            @map("unit_price")
  uom              String?
  avgRating        Float?            @map("avg_rating")
  numberOfRatings  Int?              @map("number_of_ratings")
  isSoldOut        Boolean?          @default(false) @map("is_sold_out")
  productUrl       String?           @map("product_url")
  countryCode      String?           @map("country_code")
  catalogName      String?           @map("catalog_name")
  shippingCharges  Float?            @map("shipping_charges")
  extraData        Json?             @map("extra_data")
  category_id      String?           @db.Uuid
  vertical_id      String?           @db.Uuid
  Tier2Category    Tier2Category?    @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  Vertical         Vertical?         @relation(fields: [vertical_id], references: [id], onUpdate: NoAction)
  auditLogs        ProductAuditLog[]
  images           ProductImage[]
  storeProducts    StoreProduct[]

  @@index([source])
  @@index([subcategory])
  @@index([category_id])
  @@index([vertical_id])
  @@schema("public")
}

model ProductImage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String
  url       String
  name      String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model ProductAuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  changedAt DateTime @default(now())
  changedBy String?
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model StoreProduct {
  id             String      @id @default(uuid())
  storeId        String      @db.Uuid
  productId      String
  price          Float
  stock          Int         @default(0)
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  variant        String      @default("Standard")
  is_best_seller Boolean     @default(false)
  is_deleted     Boolean     @default(false)
  product        Product     @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  store          Store       @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  orderItems     OrderItem[]

  @@unique([storeId, productId, variant])
  @@schema("public")
}

model Order {
  id                   String          @id(map: "Order_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status               OrderStatus     @default(PENDING)
  isPaid               Boolean         @default(false) @map("ispaid")
  otp                  String?
  orderNumber          String          @unique(map: "Order_order_number_key") @map("order_number")
  storeId              String          @map("store_id") @db.Uuid
  branchId             String?         @map("branch_id")
  staffId              String?         @map("staff_id")
  totalAmount          Float           @map("total_amount")
  cancelledReason      String?         @map("cancelled_reason")
  metadata             Json?           @map("metadata")
  userId               String          @map("user_id") @db.Uuid
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  returnReason         String?         @map("return_reason")
  returnImages         String[]        @map("return_images")
  customer_name        String?
  customer_phone       String?
  store_name           String?
  amount               Decimal?        @default(0) @db.Decimal(10, 2)
  order_type           String?         @default("pickup")
  otp_code             String?
  items_count          Int?            @default(0)
  special_instructions String?
  arrival_time         String?
  guests_count         Int?
  items                OrderItem[]
  store                Store           @relation(fields: [storeId], references: [id], onUpdate: NoAction, map: "fk_orders_store")
  branch               MerchantBranch? @relation(fields: [branchId], references: [id])
  user                 User            @relation("CustomerOrders", fields: [userId], references: [id], onUpdate: NoAction, map: "fk_orders_user")

  @@index([orderNumber], map: "Order_order_number_idx")
  @@index([storeId], map: "Order_store_id_idx")
  @@index([userId], map: "Order_user_id_idx")
  @@index([branchId])
  @@map("orders")
  @@schema("public")
}

model Subscription {
  id            String   @id @default(uuid())
  merchantId    String   @map("merchant_id")
  amount        Float
  currency      String   @default("INR")
  status        String
  provider      String
  transactionId String?  @map("transaction_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  merchant      Merchant @relation(fields: [merchantId], references: [id])

  @@map("subscriptions")
  @@schema("public")
}

model OrderItem {
  id             String        @id(map: "OrderItem_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quantity       Int
  price          Float         @map("price")
  orderId        String        @map("order_id") @db.Uuid
  storeProductId String?       @map("store_product_id")
  product_name   String?
  created_at     DateTime?     @default(now()) @db.Timestamptz(6)
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  storeProduct   StoreProduct? @relation(fields: [storeProductId], references: [id], onDelete: Restrict)

  @@map("order_items")
  @@schema("public")
}

model Merchant {
  id                  String           @id @default(uuid())
  storeName           String?          @map("store_name")
  branchName          String?          @map("branch_name")
  ownerName           String?          @map("owner_name")
  email               String?
  phone               String
  city                String?
  address             String?
  latitude            Float?
  longitude           Float?
  hasBranches         Boolean?         @map("has_branches")
  kycStatus           String?          @map("kyc_status")
  status              String?
  rating              Float?
  commissionRate      Float?           @map("commission_rate")
  operatingHours      String?          @map("operating_hours")
  createdAt           DateTime?        @default(now()) @map("created_at")
  updatedAt           DateTime?        @updatedAt @map("updated_at")
  operatingDays       String[]         @map("operating_days")
  panDocUrl           String?          @map("pan_doc_url")
  aadharFrontUrl      String?          @map("aadhar_front_url")
  aadharBackUrl       String?          @map("aadhar_back_url")
  kycRejectionReason  String?          @map("kyc_rejection_reason")
  panNumber           String?          @map("pan_number")
  aadharNumber        String?          @map("aadhar_number")
  bankAccountNumber   String?          @map("bank_account_number")
  ifscCode            String?          @map("ifsc_code")
  turnoverRange       String?          @map("turnover_range")
  msmeNumber          String?          @map("msme_number")
  panDocumentUrl      String?          @map("pan_document_url")
  msmeCertificateUrl  String?          @map("msme_certificate_url")
  gstNumber           String?          @map("gst_number")
  gstCertificateUrl   String?          @map("gst_certificate_url")
  storePhotos         String[]         @map("store_photos")
  bankName            String?          @map("bank_name")
  bankBeneficiaryName String?          @map("bank_beneficiary_name")
  fssaiCertificateUrl String?          @map("fssai_certificate_url")
  fssaiNumber         String?          @map("fssai_number")
  bankAccounts        Json?            @map("bank_accounts")
  verticalId          String?          @map("vertical_id") @db.Uuid
  branches            MerchantBranch[]
  Vertical            Vertical?        @relation(fields: [verticalId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscriptions       Subscription[]

  @@index([verticalId])
  @@map("merchants")
  @@schema("public")
}

model MerchantBranch {
  id                  String    @id @default(uuid())
  merchantId          String?   @map("merchant_id")
  branchName          String    @map("branch_name")
  managerName         String?   @map("manager_name")
  phone               String?
  email               String?
  address             String?
  city                String?
  latitude            Float?
  longitude           Float?
  isActive            Boolean?  @map("is_active")
  bankAccountNumber   String?   @map("bank_account_number")
  ifscCode            String?   @map("ifsc_code")
  bankName            String?   @map("bank_name")
  bankBeneficiaryName String?   @map("bank_beneficiary_name")
  permissions         Json?     @map("permissions")
  createdAt           DateTime? @default(now()) @map("created_at")
  updatedAt           DateTime? @updatedAt @map("updated_at")
  merchant            Merchant? @relation(fields: [merchantId], references: [id])
  orders              Order[]

  @@unique([merchantId, branchName])
  @@map("merchant_branches")
  @@schema("public")
}

model OtpVerification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone     String    @db.VarChar(15)
  otp       String    @db.VarChar(6)
  expiresAt DateTime  @map("expires_at") @db.Timestamp(6)
  verified  Boolean?  @default(false)
  attempts  Int?      @default(0)
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([phone], map: "idx_otp_verifications_phone")
  @@map("otp_verifications")
  @@schema("public")
}

model FavoriteStore {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String   @map("user_id")
  storeId   String   @map("store_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, storeId])
  @@map("favorite_stores")
  @@schema("public")
}

model FavoriteProduct {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId         String   @map("user_id")
  storeProductId String   @map("store_product_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([userId, storeProductId])
  @@map("favorite_products")
  @@schema("public")
}

model SyncQueue {
  id              String         @id @default(uuid())
  name            String
  brand           String?
  mrp             Float
  subcategory     String?
  image           String?
  sourceProductId String         @unique @map("source_product_id")
  status          String         @default("PENDING")
  metadata        Json?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  packsize        String?
  vertical_id     String?        @db.Uuid
  category_id     String?        @db.Uuid
  Tier2Category   Tier2Category? @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  Vertical        Vertical?      @relation(fields: [vertical_id], references: [id], onUpdate: NoAction)

  @@index([status])
  @@index([sourceProductId])
  @@map("sync_queue")
  @@schema("public")
}

