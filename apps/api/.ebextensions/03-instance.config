# Instance sizing + deploy timeout.
# Root cause of past failed deploys/outages: t3.micro (1 GB RAM) thrashed during
# `npm install` + `prisma generate`, so installs took ~45 min and blew the default
# 600s command timeout. t3.small (2 GB) removes the memory pressure; the 3600s
# timeout is a safety net so a slow install can never fail the deploy again.
option_settings:
  aws:autoscaling:launchconfiguration:
    InstanceType: t3.small
  aws:ec2:instances:
    InstanceTypes: t3.small
  aws:elasticbeanstalk:command:
    Timeout: 3600
